<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tuowei.dazhongdianping.module.growth.mapper.GrowthConfigMapper">
 <sql id="ruleColumns">id,action,action_name,growth_value,points,daily_limit,enabled,updated_at</sql>
 <select id="selectRules" resultType="com.tuowei.dazhongdianping.module.auth.model.GrowthRuleRow">SELECT <include refid="ruleColumns"/> FROM growth_rule ORDER BY id</select>
 <select id="selectRule" resultType="com.tuowei.dazhongdianping.module.auth.model.GrowthRuleRow">SELECT <include refid="ruleColumns"/> FROM growth_rule WHERE id=#{id}</select>
 <select id="selectRuleByAction" resultType="com.tuowei.dazhongdianping.module.auth.model.GrowthRuleRow">SELECT <include refid="ruleColumns"/> FROM growth_rule WHERE action=#{action}</select>
 <select id="selectLevels" resultType="com.tuowei.dazhongdianping.module.growth.model.LevelConfigRow">SELECT level,min_growth,level_name,icon,privilege_json,enabled,updated_at FROM level_config ORDER BY level</select>
 <select id="selectLevel" resultType="com.tuowei.dazhongdianping.module.growth.model.LevelConfigRow">SELECT level,min_growth,level_name,icon,privilege_json,enabled,updated_at FROM level_config WHERE level=#{level}</select>
 <insert id="insertRule" useGeneratedKeys="true" keyProperty="id">INSERT INTO growth_rule(action,action_name,growth_value,points,daily_limit,enabled) VALUES(#{action},#{actionName},#{growthValue},#{points},#{dailyLimit},#{enabled})</insert>
 <update id="updateRule">UPDATE growth_rule SET action=#{action},action_name=#{actionName},growth_value=#{growthValue},points=#{points},daily_limit=#{dailyLimit},enabled=#{enabled},updated_at=CURRENT_TIMESTAMP WHERE id=#{id}</update>
 <update id="updateLevel">UPDATE level_config SET min_growth=#{minGrowth},level_name=#{levelName},icon=#{icon},privilege_json=#{privilegeJson},enabled=#{enabled},updated_at=CURRENT_TIMESTAMP WHERE level=#{level}</update>
</mapper>
