<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tuowei.dazhongdianping.module.notification.mapper.MentionMapper">
  <select id="selectActiveUsersByNicknames" resultType="com.tuowei.dazhongdianping.module.notification.model.MentionUserRow">
    SELECT id,nickname FROM app_user
    WHERE status=1 AND is_deleted=FALSE AND nickname IN
    <foreach collection="nicknames" item="nickname" open="(" separator="," close=")">#{nickname}</foreach>
    ORDER BY id
  </select>
</mapper>
